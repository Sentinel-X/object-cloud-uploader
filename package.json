{
  "name": "@sentinelx/object-cloud-uploader",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepare": "npm run build",
    "build": "npx tsc",
    "eslint": "eslint ./src",
    "eslint_fix": "eslint ./src --fix",
    "test": "mocha -r tsx/cjs 'tests/**/**.test.ts' --timeout 180000 --exit",
    "test_file": "mocha -r tsx/cjs --timeout 180000 --exit",
    "coverage": "nyc --reporter=html --reporter=text --reporter=lcov mocha -r tsx/cjs 'tests/**/**.test.ts' --timeout 180000 --exit && nyc report --reporter=cobertura && mv ./coverage/cobertura-coverage.xml ./coverage.cobertura.xml",
    "devops_coverage": "nyc mocha -r tsx/cjs 'tests/**/**.test.ts' --reporter ./tests/assets/multiple_reporters.js --timeout 180000 --exit",
    "generate_cobertura": "nyc report --reporter=cobertura",
    "ts-prune": "ts-prune --error --ignore 'eslint.config.mjs|index.ts'",
    "check-unused-class-methods": "ts-node ./tests/assets/find_unused_class_methods.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sentinel-X/object-cloud-uploader.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Sentinel-X/object-cloud-uploader/issues"
  },
  "homepage": "https://github.com/Sentinel-X/object-cloud-uploader#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@azure/storage-blob": "^12.31.0",
    "@eslint/eslintrc": "^3.3.5",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "chai": "^6.2.2",
    "eslint": "^10.3.0",
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "^2.2.1",
    "nyc": "^18.0.0",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
